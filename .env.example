# No dashboard access token is required for local diagnostics and copy generation.
# The app invokes the locally configured Hermes Agent runtime using a fixed workflow.
# Do not expose this cost-bearing endpoint publicly without deployment-level
# authentication and shared rate limiting.

# Optional shared key that guards the cost-bearing /api/audits endpoint.
# When set, clients must send header `x-kairo-key: <value>`. Leave unset to leave it open.
# KAIRO_API_KEY=replace-me

# Live vs preview mode. The app runs LIVE on a stateful host by default. Set to 0 to
# force preview mode (sample result only), or 1 on Vercel to attempt live (not recommended
# on serverless — there is no persistent process/filesystem for the worker).
# KAIRO_LIVE=1

